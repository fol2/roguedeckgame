+      writeFileSync(join(projectRoot, "debug.log"), "local log\n");
+      writeFileSync(join(projectRoot, "notes.txt"), "local scratch\n");
+      writeFileSync(join(projectRoot, "docs/private/client.key"), "do-not-archive\n");
