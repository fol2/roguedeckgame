+
+    try {
+      mkdirSync(join(projectRoot, "src/game-core"), { recursive: true });
+      mkdirSync(join(projectRoot, "src/secrets"), { recursive: true });
+      mkdirSync(join(projectRoot, "scripts"), { recursive: true });
