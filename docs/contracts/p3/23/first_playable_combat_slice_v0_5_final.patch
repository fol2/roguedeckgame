index 0000000..e88d085
--- /dev/null
+++ b/src/game-core/systems/card-actor-runtime.ts
@@ -0,0 +1,431 @@
+import { cardInstanceId, monsterIntentId, type CardId, type CardInstanceId, type CombatantId, type MonsterAbilityId } from "../ids";
+import type {
+  ActorCardInstance,
+  ActorCardKind,
+  ActorCardZone,
+  CardActorResources,
+  CombatCardActorState,
+  CombatCardInstance,
+  CombatMonsterCardState,
+  CombatState,
+  PlannedMonsterAbility
+} from "../model/combat";
+import type { GameEvent } from "../model/event";
+import type { MonsterAbilityDefinition } from "../model/monster";
+import type { Rng } from "./rng";
+
+export const PLAYER_CARD_ACTOR_ID = "player" as CombatantId;
+
+export const defaultPlayerActorResources = (): CardActorResources => ({
+  openingHandSize: 5,
+  drawPerTurn: 3,
+  maxHandSize: 10,
+  maxEnergy: 3,
+  energyRefill: 3,
+  energy: 3,
+  unplayedHandPolicy: "retain"
+});
+
+export const createPlayerCardActor = (input: {
+  readonly actorId: CombatantId;
+  readonly cards: readonly CombatCardInstance[];
+  readonly shuffledDrawPile: readonly CardInstanceId[];
+  readonly resources?: Partial<CardActorResources>;
+}): CombatCardActorState => {
+  const base = defaultPlayerActorResources();
+  return {
+    actorId: input.actorId,
+    actorKind: "player",
+    controllerKind: "human",
+    side: "playerSide",
+    teamId: "player",
+    resources: { ...base, ...input.resources, unplayedHandPolicy: "retain" },
+    cardInstances: input.cards.map((card) => ({
+      id: card.id,
+      ownerId: input.actorId,
+      kind: "playerCard" as const,
+      cardId: card.cardId
+    })),
+    drawPile: input.shuffledDrawPile,
+    hand: [],
+    planned: [],
+    discardPile: [],
+    exhaustPile: []
+  };
+};
+
+export const createEnemyCardActor = (input: {
+  readonly actorId: CombatantId;
+  readonly monsterTags: readonly string[];
+  readonly abilities: readonly MonsterAbilityDefinition[];
+  readonly deck: readonly { readonly abilityId: MonsterAbilityId; readonly copies: number }[];
+  readonly shuffledDrawPile?: readonly CardInstanceId[];
+  readonly resources: CardActorResources;
+  readonly ai?: CombatCardActorState["ai"];
+}): CombatCardActorState => {
+  const instances: ActorCardInstance[] = input.deck.flatMap((entry) => {
+    const ability = input.abilities.find((candidate) => candidate.id === entry.abilityId);
+    if (!ability) {
+      return [];
+    }
+
+    return Array.from({ length: entry.copies }, (_ignored, index) => ({
+      id: cardInstanceId(`${input.actorId}:ability-card:${entry.abilityId}:${index}`),
+      ownerId: input.actorId,
+      kind: "enemyAbility" as const,
+      abilityId: entry.abilityId
+    }));
+  });
+  const drawPile = input.shuffledDrawPile ?? instances.map((instance) => instance.id);
+  const isLeader = input.ai?.teamRole === "leader";
+  return {
+    actorId: input.actorId,
+    actorKind: "enemy",
+    controllerKind: isLeader ? "leaderHeuristic" : "heuristicAi",
+    side: "enemySide",
+    teamId: "enemy",
+    resources: input.resources,
+    cardInstances: instances,
+    drawPile,
+    hand: [],
+    planned: [],
+    discardPile: [],
+    exhaustPile: [],
+    ai: input.ai
+  };
+};
+
+export const findCardActor = (
+  state: CombatState,
+  actorId: CombatantId
+): CombatCardActorState | undefined => state.cardActors.find((actor) => actor.actorId === actorId);
+
+export const findActorCard = (
+  actor: CombatCardActorState,
+  cardInstanceIdValue: CardInstanceId
+): ActorCardInstance | undefined => actor.cardInstances.find((card) => card.id === cardInstanceIdValue);
+
+const getActorPile = (actor: CombatCardActorState, zone: ActorCardZone): readonly CardInstanceId[] => {
+  switch (zone) {
+    case "draw": return actor.drawPile;
+    case "hand": return actor.hand;
+    case "planned": return actor.planned;
+    case "discard": return actor.discardPile;
+    case "exhaust": return actor.exhaustPile;
+  }
+};
+
+const setActorPile = (
+  actor: CombatCardActorState,
+  zone: ActorCardZone,
+  cards: readonly CardInstanceId[]
+): CombatCardActorState => {
+  switch (zone) {
+    case "draw": return { ...actor, drawPile: cards };
+    case "hand": return { ...actor, hand: cards };
+    case "planned": return { ...actor, planned: cards };
+    case "discard": return { ...actor, discardPile: cards };
+    case "exhaust": return { ...actor, exhaustPile: cards };
+  }
+};
+
+const definitionIdForActorCard = (card: ActorCardInstance): CardId | MonsterAbilityId => {
+  if (card.kind === "playerCard" && card.cardId) {
+    return card.cardId;
+  }
+  if (card.kind === "enemyAbility" && card.abilityId) {
+    return card.abilityId;
+  }
+  return card.id as unknown as CardId;
+};
+
+export const updateCardActor = (
+  state: CombatState,
+  actorId: CombatantId,
+  update: (actor: CombatCardActorState) => CombatCardActorState
+): CombatState => syncCombatProjections({
+  ...state,
+  cardActors: state.cardActors.map((actor) => actor.actorId === actorId ? update(actor) : actor)
+});
+
+const removeFirst = (
+  cards: readonly CardInstanceId[],
+  cardInstanceIdValue: CardInstanceId
+): readonly CardInstanceId[] | undefined => {
+  const index = cards.indexOf(cardInstanceIdValue);
+  if (index < 0) {
+    return undefined;
+  }
+  return [...cards.slice(0, index), ...cards.slice(index + 1)];
+};
+
+export const moveActorCard = (input: {
+  readonly state: CombatState;
+  readonly actorId: CombatantId;
+  readonly cardInstanceId: CardInstanceId;
+  readonly from: ActorCardZone;
+  readonly to: ActorCardZone;
+}): { readonly ok: true; readonly state: CombatState; readonly events: readonly GameEvent[] } | { readonly ok: false; readonly error: string } => {
+  const actor = findCardActor(input.state, input.actorId);
+  if (!actor) {
+    return { ok: false, error: `Missing card actor '${input.actorId}'.` };
+  }
+  const card = findActorCard(actor, input.cardInstanceId);
+  if (!card) {
+    return { ok: false, error: `Missing card instance '${input.cardInstanceId}'.` };
+  }
+  const sourcePile = getActorPile(actor, input.from);
+  const nextSourcePile = removeFirst(sourcePile, input.cardInstanceId);
+  if (!nextSourcePile) {
+    return { ok: false, error: `Card instance '${input.cardInstanceId}' is not in ${input.from}.` };
+  }
+  const actorWithoutCard = setActorPile(actor, input.from, nextSourcePile);
+  const targetPile = getActorPile(actorWithoutCard, input.to);
+  const nextActor = setActorPile(actorWithoutCard, input.to, [...targetPile, input.cardInstanceId]);
+  const actorEvent: GameEvent = {
+    type: "ActorCardMoved",
+    actorId: input.actorId,
+    cardInstanceId: input.cardInstanceId,
+    cardKind: card.kind,
+    definitionId: definitionIdForActorCard(card),
+    from: input.from,
+    to: input.to
+  };
+  const canMirrorAsPlayerPileMove = (zone: ActorCardZone): zone is "draw" | "hand" | "discard" | "exhaust" => zone !== "planned";
+  const legacyPlayerEvent: GameEvent | undefined = input.actorId === PLAYER_CARD_ACTOR_ID &&
+    card.kind === "playerCard" &&
+    card.cardId &&
+    canMirrorAsPlayerPileMove(input.from) &&
+    canMirrorAsPlayerPileMove(input.to)
+    ? { type: "CardMoved", cardInstanceId: input.cardInstanceId, cardId: card.cardId, from: input.from, to: input.to }
+    : undefined;
+  const events = legacyPlayerEvent ? [actorEvent, legacyPlayerEvent] : [actorEvent];
+  const nextState = syncCombatProjections({
+    ...input.state,
+    cardActors: input.state.cardActors.map((candidate) => candidate.actorId === input.actorId ? nextActor : candidate),
+    events: [...input.state.events, ...events]
+  });
+
+  return { ok: true, state: nextState, events };
+};
+
+export const setActorEnergy = (
+  state: CombatState,
+  actorId: CombatantId,
+  energy: number
+): CombatState => updateCardActor(state, actorId, (actor) => ({
+  ...actor,
+  resources: { ...actor.resources, energy }
+}));
+
+export const spendActorEnergy = (input: {
+  readonly state: CombatState;
+  readonly actorId: CombatantId;
+  readonly amount: number;
+}): { readonly ok: true; readonly state: CombatState } | { readonly ok: false; readonly error: string } => {
+  const actor = findCardActor(input.state, input.actorId);
+  if (!actor) {
+    return { ok: false, error: `Missing card actor '${input.actorId}'.` };
+  }
+  if (actor.resources.energy < input.amount) {
+    return { ok: false, error: `Actor '${input.actorId}' has insufficient energy.` };
+  }
+  return { ok: true, state: setActorEnergy(input.state, input.actorId, actor.resources.energy - input.amount) };
+};
+
+export const refillActorEnergy = (
+  state: CombatState,
+  actorId: CombatantId
+): { readonly state: CombatState; readonly events: readonly GameEvent[] } => {
+  const actor = findCardActor(state, actorId);
+  if (!actor) {
+    return { state, events: [] };
+  }
+  const event: GameEvent = {
+    type: "ActorEnergyRefilled",
+    actorId,
+    amount: actor.resources.energyRefill,
+    total: actor.resources.energyRefill
+  };
+  const nextState = updateCardActor({ ...state, events: [...state.events, event] }, actorId, (candidate) => ({
+    ...candidate,
+    resources: { ...candidate.resources, energy: candidate.resources.energyRefill }
+  }));
+  return { state: nextState, events: [event] };
+};
+
+
+export const returnActorPlannedCardsToHand = (
+  state: CombatState,
+  actorId: CombatantId
+): { readonly ok: true; readonly state: CombatState; readonly events: readonly GameEvent[] } | { readonly ok: false; readonly error: string } => {
+  let nextState = state;
+  const events: GameEvent[] = [];
+  const actor = findCardActor(nextState, actorId);
+  if (!actor) {
+    return { ok: false, error: `Missing card actor '${actorId}'.` };
+  }
+
+  for (const cardInstanceIdValue of actor.planned) {
+    const move = moveActorCard({ state: nextState, actorId, cardInstanceId: cardInstanceIdValue, from: "planned", to: "hand" });
+    if (!move.ok) {
+      return move;
+    }
+    nextState = move.state;
+    events.push(...move.events);
+  }
+
+  return { ok: true, state: nextState, events };
+};
+
+export const setActorPlannedCards = (
+  state: CombatState,
+  actorId: CombatantId,
+  plannedCardInstanceIds: readonly CardInstanceId[]
+): { readonly ok: true; readonly state: CombatState; readonly events: readonly GameEvent[] } | { readonly ok: false; readonly error: string } => {
+  const returned = returnActorPlannedCardsToHand(state, actorId);
+  if (!returned.ok) {
+    return returned;
+  }
+
+  let nextState = returned.state;
+  const events: GameEvent[] = [...returned.events];
+  for (const cardInstanceIdValue of plannedCardInstanceIds) {
+    const move = moveActorCard({ state: nextState, actorId, cardInstanceId: cardInstanceIdValue, from: "hand", to: "planned" });
+    if (!move.ok) {
+      return move;
+    }
+    nextState = move.state;
+    events.push(...move.events);
+  }
+
+  return { ok: true, state: nextState, events };
+};
+
+export const drawCardsForActor = (
+  state: CombatState,
+  actorId: CombatantId,
+  count: number,
+  rng: Rng
+): { readonly ok: true; readonly state: CombatState; readonly events: readonly GameEvent[] } | { readonly ok: false; readonly error: string } => {
+  let nextState = state;
+  const events: GameEvent[] = [];
+
+  for (let index = 0; index < count; index += 1) {
+    const actor = findCardActor(nextState, actorId);
+    if (!actor) {
+      return { ok: false, error: `Missing card actor '${actorId}'.` };
+    }
+    if (actor.hand.length >= actor.resources.maxHandSize) {
+      break;
+    }
+    if (actor.drawPile.length === 0 && actor.discardPile.length > 0) {
+      const shuffled = rng.shuffle(actor.discardPile);
+      const shuffleEvent: GameEvent = { type: "ActorDeckShuffled", actorId, from: "discard", to: "draw", count: shuffled.length };
+      nextState = updateCardActor({ ...nextState, events: [...nextState.events, shuffleEvent] }, actorId, (candidate) => ({
+        ...candidate,
+        drawPile: shuffled,
+        discardPile: []
+      }));
+      events.push(shuffleEvent);
+    }
+    const refreshedActor = findCardActor(nextState, actorId);
+    const cardInstanceIdValue = refreshedActor?.drawPile[0];
+    if (!cardInstanceIdValue) {
+      break;
+    }
+    const move = moveActorCard({ state: nextState, actorId, cardInstanceId: cardInstanceIdValue, from: "draw", to: "hand" });
+    if (!move.ok) {
+      return move;
+    }
+    nextState = move.state;
+    events.push(...move.events);
+    const actorAfterMove = findCardActor(nextState, actorId);
+    const card = actorAfterMove ? findActorCard(actorAfterMove, cardInstanceIdValue) : undefined;
+    if (card) {
+      const drawnEvent: GameEvent = {
+        type: "ActorCardDrawn",
+        actorId,
+        cardInstanceId: cardInstanceIdValue,
+        cardKind: card.kind,
+        definitionId: definitionIdForActorCard(card)
+      };
+      nextState = { ...nextState, events: [...nextState.events, drawnEvent] };
+      events.push(drawnEvent);
+      if (actorId === PLAYER_CARD_ACTOR_ID && card.kind === "playerCard" && card.cardId) {
+        const playerDrawnEvent: GameEvent = { type: "CardDrawn", cardInstanceId: cardInstanceIdValue, cardId: card.cardId };
+        nextState = { ...nextState, events: [...nextState.events, playerDrawnEvent] };
+        events.push(playerDrawnEvent);
+      }
+    }
+  }
+
+  return { ok: true, state: syncCombatProjections(nextState), events };
+};
+
+export const syncCombatProjections = (state: CombatState): CombatState => {
+  const playerActor = state.cardActors.find((actor) => actor.actorId === PLAYER_CARD_ACTOR_ID);
+  const playerCards = playerActor?.cardInstances
+    .filter((card): card is ActorCardInstance & { readonly kind: "playerCard"; readonly cardId: CardId } => card.kind === "playerCard" && card.cardId !== undefined)
+    .map((card) => ({ id: card.id, cardId: card.cardId, ownerId: card.ownerId })) ?? state.cardInstances;
