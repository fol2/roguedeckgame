--- /dev/null
+++ b/src/game-core/systems/enemy-ai.ts
@@ -0,0 +1,384 @@
+import { type CardInstanceId, type CombatantId } from "../ids";
+import type {
+  ActorCardInstance,
+  CardActorPlanSequence,
+  CardActorPlanState,
+  CardActorPlanStep,
+  CombatCardActorState,
+  CombatState,
+  CombatTeamPlanState
+} from "../model/combat";
+import type { EffectDefinition } from "../model/effect";
+import type { GameEvent } from "../model/event";
+import type { EnemyPlanMode, MonsterAbilityDefinition } from "../model/monster";
+import type { GameContentRegistry } from "../model/registry";
+import { findActorCard, setActorPlannedCards, syncCombatProjections } from "./card-actor-runtime";
+import { resolveEffectiveIntentVisibilityLevel } from "./intent-visibility";
+
+const byText = (left: string, right: string): number => left.localeCompare(right, "en-GB");
+
+const abilityById = (registry: GameContentRegistry): Map<string, MonsterAbilityDefinition> =>
+  new Map((registry.monsterAbilities ?? []).map((ability) => [String(ability.id), ability]));
+
+const getAbilityForCard = (
+  registry: GameContentRegistry,
+  actor: CombatCardActorState,
+  cardInstanceId: CardInstanceId
+): MonsterAbilityDefinition | undefined => {
+  const card = findActorCard(actor, cardInstanceId);
+  if (!card?.abilityId) {
+    return undefined;
+  }
+  return abilityById(registry).get(String(card.abilityId));
+};
+
+const hasTag = (ability: MonsterAbilityDefinition, tag: string): boolean => ability.tags.includes(tag);
+
+const firstOpponentTarget = (state: CombatState, actor: CombatCardActorState): CombatantId | undefined => {
+  if (actor.side === "enemySide") {
+    return state.player.alive ? state.player.id : undefined;
+  }
+  return state.monsters.find((monster) => monster.alive)?.id;
+};
+
+const scoreEffect = (input: {
+  readonly state: CombatState;
+  readonly actor: CombatCardActorState;
+  readonly ability: MonsterAbilityDefinition;
+  readonly effect: EffectDefinition;
+  readonly remainingPlayerHp: number;
+  readonly remainingPlayerBlock: number;
+  readonly actorProjectedBlock: number;
+}): { readonly score: number; readonly tags: readonly string[] } => {
+  const weights = input.actor.ai?.weights ?? {};
+  const damageWeight = weights.damage ?? 1;
+  const survivalWeight = weights.selfSurvival ?? 1;
+  const debuffWeight = weights.debuff ?? 1;
+  const setupWeight = weights.setup ?? 1;
+  const obscureWeight = weights.obscure ?? 1;
+
+  if (input.effect.type === "damage" || input.effect.type === "petAttack") {
+    const raw = input.effect.amount;
+    const damage = Math.max(0, raw - input.remainingPlayerBlock);
+    const lethal = damage >= input.remainingPlayerHp;
+    return {
+      score: damage * 2.5 * damageWeight + (lethal ? (weights.lethal ?? 10000) : 0),
+      tags: lethal ? ["lethal", "damage"] : ["damage"]
+    };
+  }
+
+  if (input.effect.type === "applyStatus") {
+    const isBurn = String(input.effect.statusId) === "burn" || hasTag(input.ability, "burn");
+    return {
+      score: input.effect.stacks * (isBurn ? 4 : 2) * debuffWeight,
+      tags: [isBurn ? "burn" : "debuff"]
+    };
+  }
+
+  if (input.effect.type === "block" || input.effect.type === "petBlock") {
+    const actorCombatant = input.state.monsters.find((monster) => monster.id === input.actor.actorId) ?? input.state.player;
+    const dangerRatio = actorCombatant.maxHp > 0 ? 1 - actorCombatant.hp / actorCombatant.maxHp : 0;
+    const overblockPenalty = input.actorProjectedBlock > actorCombatant.maxHp * 0.35 ? 0.45 : 1;
+    return {
+      score: input.effect.amount * (0.6 + dangerRatio * 1.8) * survivalWeight * overblockPenalty,
+      tags: ["survive", "block"]
+    };
+  }
+
+  if (input.effect.type === "obscureIntent") {
+    const monsterDefinition = input.state.monsters.find((monster) => monster.id === input.actor.actorId)?.definitionId;
+    const definition = monsterDefinition
+      ? input.state.monsters.find((monster) => monster.id === input.actor.actorId)
+      : undefined;
+    void definition;
+    return { score: 3.5 * obscureWeight, tags: ["obscure"] };
+  }
+
+  if (input.effect.type === "cleanseStatus" || input.effect.type === "consumeStatus") {
+    return { score: 2 * survivalWeight, tags: ["cleanse"] };
+  }
+
+  if (input.effect.type === "draw" || input.effect.type === "gainEnergy" || input.effect.type === "createCard") {
+    return { score: 2.5 * setupWeight, tags: ["card-economy"] };
+  }
+
+  if (input.effect.type === "improveIntentVisibility" || input.effect.type === "revealIntent" || input.effect.type === "scopeIntent") {
+    return { score: 1.5 * setupWeight, tags: ["information"] };
+  }
+
+  return { score: hasTag(input.ability, "charge") ? 3 * setupWeight : 0.5 * setupWeight, tags: hasTag(input.ability, "charge") ? ["setup", "charge"] : ["utility"] };
+};
+
+const scoreSequence = (
+  state: CombatState,
+  actor: CombatCardActorState,
+  steps: readonly CardActorPlanStep[],
+  registry: GameContentRegistry
+): CardActorPlanSequence => {
+  let remainingPlayerHp = state.player.hp;
+  let remainingPlayerBlock = state.player.block;
+  let actorProjectedBlock = state.monsters.find((monster) => monster.id === actor.actorId)?.block ?? 0;
+  let score = 0;
+  const reasonTags: string[] = [];
+
+  for (const step of steps) {
+    const ability = step.abilityId ? abilityById(registry).get(String(step.abilityId)) : undefined;
+    if (!ability) {
+      continue;
+    }
+    score += (actor.ai?.weights?.cardEfficiency ?? 1) * 0.1;
+    for (const effect of ability.effects) {
+      const effectScore = scoreEffect({ state, actor, ability, effect, remainingPlayerHp, remainingPlayerBlock, actorProjectedBlock });
+      score += effectScore.score;
+      reasonTags.push(...effectScore.tags);
+      if (effect.type === "damage" || effect.type === "petAttack") {
+        const blocked = Math.min(remainingPlayerBlock, effect.amount);
+        remainingPlayerBlock = Math.max(0, remainingPlayerBlock - blocked);
+        remainingPlayerHp = Math.max(0, remainingPlayerHp - Math.max(0, effect.amount - blocked));
+      }
+      if (effect.type === "block" || effect.type === "petBlock") {
+        actorProjectedBlock += effect.amount;
+      }
+    }
+  }
+
+  const uniqueReasonTags = [...new Set(reasonTags)].sort(byText);
+  return { actorId: actor.actorId, steps, score, reasonTags: uniqueReasonTags };
+};
+
+const planModeForSequence = (
+  actor: CombatCardActorState,
+  sequence: CardActorPlanSequence,
+  registry: GameContentRegistry
+): EnemyPlanMode => {
+  const abilities = sequence.steps
+    .map((step) => step.abilityId ? abilityById(registry).get(String(step.abilityId)) : undefined)
+    .filter((ability): ability is MonsterAbilityDefinition => ability !== undefined);
+  if (abilities.some((ability) => ability.planMode === "charging" || ability.intentType === "charge")) {
+    return "charging";
+  }
+  if (actor.controllerKind === "leaderHeuristic" || (actor.resources.maxEnergy > 1 && abilities.length > 1)) {
+    return "adaptive";
+  }
+  return abilities[0]?.planMode ?? "locked";
+};
+
+const buildStep = (
+  state: CombatState,
+  actor: CombatCardActorState,
+  card: ActorCardInstance,
+  ability: MonsterAbilityDefinition
+): CardActorPlanStep => ({
+  actorId: actor.actorId,
+  cardInstanceId: card.id,
+  kind: card.kind,
+  abilityId: card.abilityId,
+  targetId: firstOpponentTarget(state, actor),
+  intentType: ability.intentType,
+  reasonTags: ability.tags
+});
+
+const enumerateSequences = (
+  state: CombatState,
+  actor: CombatCardActorState,
+  registry: GameContentRegistry
+): readonly CardActorPlanSequence[] => {
+  const candidates = actor.hand
+    .map((cardInstanceId) => {
+      const card = findActorCard(actor, cardInstanceId);
+      const ability = card ? getAbilityForCard(registry, actor, cardInstanceId) : undefined;
+      return card && ability ? { card, ability } : undefined;
+    })
+    .filter((candidate): candidate is { readonly card: ActorCardInstance; readonly ability: MonsterAbilityDefinition } => candidate !== undefined)
+    .sort((left, right) => byText(String(left.card.id), String(right.card.id)));
+  const maxPlays = actor.resources.maxCardPlaysPerActionWindow ?? actor.resources.maxEnergy;
+  const sequences: CardActorPlanSequence[] = [scoreSequence(state, actor, [], registry)];
+
+  const visit = (
+    remaining: readonly { readonly card: ActorCardInstance; readonly ability: MonsterAbilityDefinition }[],
+    energy: number,
+    steps: readonly CardActorPlanStep[]
+  ) => {
+    if (steps.length >= maxPlays) {
+      return;
+    }
+    for (let index = 0; index < remaining.length; index += 1) {
+      const candidate = remaining[index];
+      if (!candidate || candidate.ability.cost > energy) {
+        continue;
+      }
+      const nextSteps = [...steps, buildStep(state, actor, candidate.card, candidate.ability)];
+      sequences.push(scoreSequence(state, actor, nextSteps, registry));
+      visit([...remaining.slice(0, index), ...remaining.slice(index + 1)], energy - candidate.ability.cost, nextSteps);
+    }
+  };
+
+  visit(candidates, actor.resources.energy, []);
+  return sequences
+    .sort((left, right) => right.score - left.score || byText(left.steps.map((step) => String(step.cardInstanceId)).join(">"), right.steps.map((step) => String(step.cardInstanceId)).join(">")))
+    .slice(0, actor.ai?.candidateBeamWidth ?? 8);
+};
+
+const sequenceIds = (sequence: CardActorPlanSequence | undefined): readonly CardInstanceId[] =>
+  sequence?.steps.map((step) => step.cardInstanceId) ?? [];
+
+const sameSequence = (left: readonly CardInstanceId[], right: readonly CardInstanceId[]): boolean =>
+  left.length === right.length && left.every((value, index) => value === right[index]);
+
+const createPlanForActor = (
+  state: CombatState,
+  actor: CombatCardActorState,
+  registry: GameContentRegistry
+): CardActorPlanState => {
+  const candidateSequences = enumerateSequences(state, actor, registry);
+  const sequence = candidateSequences[0] ?? scoreSequence(state, actor, [], registry);
+  return {
+    actorId: actor.actorId,
+    mode: planModeForSequence(actor, sequence, registry),
+    sequence,
+    candidateSequences,
+    committed: false,
+    generatedAtTurn: state.turnNumber
+  };
+};
+
+const executionOrderForPlans = (
+  actors: readonly CombatCardActorState[],
+  plans: readonly CardActorPlanState[],
+  leader: CombatCardActorState | undefined
+): readonly CombatantId[] => {
+  const scoreForActor = (actorId: CombatantId): number => {
+    const plan = plans.find((candidate) => candidate.actorId === actorId);
+    const firstIntent = plan?.sequence.steps[0]?.intentType;
+    if (firstIntent === "debuff" || firstIntent === "special") return 0;
+    if (firstIntent === "charge" || firstIntent === "buff") return 1;
+    if (firstIntent === "block") return leader?.actorId === actorId ? 3 : 2;
+    if (firstIntent === "attack") return 4;
+    return 5;
+  };
+  return actors
+    .map((actor) => actor.actorId)
+    .sort((left, right) => scoreForActor(left) - scoreForActor(right) || byText(String(left), String(right)));
+};
+
+export const planEnemyTeam = (
+  state: CombatState,
+  registry: GameContentRegistry,
+  options: { readonly reason?: "initial" | "replan" | "nextTurn" } = {}
+): { readonly state: CombatState; readonly events: readonly GameEvent[] } => {
+  let planningState = state;
+  const events: GameEvent[] = [];
+
+  const aliveEnemyActorIds = new Set(
+    state.monsters.filter((monster) => monster.alive).map((monster) => monster.id)
+  );
+
+  for (const actor of state.cardActors.filter((candidate) => candidate.actorKind === "enemy" && aliveEnemyActorIds.has(candidate.actorId))) {
+    if (actor.planned.length === 0) {
+      continue;
+    }
+    const returned = setActorPlannedCards(planningState, actor.actorId, []);
+    if (!returned.ok) {
+      throw new Error(returned.error);
+    }
+    planningState = returned.state;
+    events.push(...returned.events);
+  }
+
+  const enemyActors = planningState.cardActors.filter((actor) =>
+    actor.actorKind === "enemy" && planningState.monsters.some((monster) => monster.id === actor.actorId && monster.alive)
+  );
+  const leader = enemyActors.find((actor) => actor.ai?.teamRole === "leader" && actor.ai.canPlanAllies);
+  const nextPlans = enemyActors.map((actor) => createPlanForActor(planningState, actor, registry));
+
+  let nextState = planningState;
+  const planEvents: GameEvent[] = [];
+  for (const actor of enemyActors) {
+    const nextPlan = nextPlans.find((plan) => plan.actorId === actor.actorId);
+    if (!nextPlan) {
+      nextState = syncCombatProjections({
+        ...nextState,
+        cardActors: nextState.cardActors.map((candidate) => candidate.actorId === actor.actorId ? { ...candidate, planned: [], plan: undefined } : candidate)
+      });
+      continue;
+    }
+
+    const previousIds = sequenceIds(actor.plan?.sequence);
+    const nextIds = sequenceIds(nextPlan.sequence);
+    const planned = setActorPlannedCards(nextState, actor.actorId, nextIds);
+    if (!planned.ok) {
+      throw new Error(planned.error);
+    }
+    nextState = syncCombatProjections({
+      ...planned.state,
+      cardActors: planned.state.cardActors.map((candidate) => candidate.actorId === actor.actorId ? { ...candidate, plan: nextPlan } : candidate)
+    });
+    events.push(...planned.events);
+
+    if (actor.plan && !sameSequence(previousIds, nextIds)) {
+      planEvents.push({
+        type: "ActorPlanChanged",
+        actorId: actor.actorId,
+        fromCardInstanceIds: previousIds,
+        toCardInstanceIds: nextIds,
+        reasonTags: nextPlan.sequence.reasonTags
+      });
+    } else {
+      planEvents.push({
+        type: "ActorPlanCreated",
+        actorId: actor.actorId,
+        planMode: nextPlan.mode,
+        sequenceCardInstanceIds: nextIds,
+        candidateCount: nextPlan.candidateSequences.length,
+        reasonTags: nextPlan.sequence.reasonTags
+      });
+    }
+  }
+
+  const order = executionOrderForPlans(enemyActors, nextPlans, leader);
+  const teamPlan: CombatTeamPlanState = {
+    teamId: "enemy",
+    leaderActorId: leader?.actorId,
+    sequences: nextPlans.map((plan) => plan.sequence),
+    executionOrder: order,
+    score: nextPlans.reduce((sum, plan) => sum + plan.sequence.score, 0),
+    reasonTags: [...new Set(nextPlans.flatMap((plan) => plan.sequence.reasonTags))].sort(byText),
+    generatedAtTurn: planningState.turnNumber
+  };
+  planEvents.push({
+    type: options.reason === "replan" ? "TeamPlanChanged" : "TeamPlanCreated",
+    teamId: teamPlan.teamId,
+    leaderActorId: leader?.actorId,
+    actorIds: order,
+    reasonTags: teamPlan.reasonTags
+  });
+
+  const stateWithPlan = syncCombatProjections({
+    ...nextState,
+    teamPlans: [teamPlan],
+    events: [...nextState.events, ...planEvents]
+  });
+
+  return {
+    state: stateWithPlan,
+    events: [...events, ...planEvents]
+  };
+};
+
+export const resolvePlanVisibilityReasonTags = (
+  state: CombatState,
+  actorId: CombatantId,
+  registry: GameContentRegistry
+): readonly string[] => {
+  const monster = state.monsters.find((candidate) => candidate.id === actorId);
+  const actor = state.cardActors.find((candidate) => candidate.actorId === actorId);
+  if (!monster || !actor?.plan) {
+    return [];
+  }
+  const monsterDefinition = monster.definitionId ? registry.monsters.find((definition) => definition.id === monster.definitionId) : undefined;
+  const ability = actor.plan.sequence.steps[0]?.abilityId
+    ? registry.monsterAbilities?.find((candidate) => candidate.id === actor.plan?.sequence.steps[0]?.abilityId)
+    : undefined;
+  const level = resolveEffectiveIntentVisibilityLevel({ state, registry, monsterCombatantId: actorId, monsterDefinition, ability });
+  return level === "scoped" || level === "exact" ? actor.plan.sequence.reasonTags : [];
+};
