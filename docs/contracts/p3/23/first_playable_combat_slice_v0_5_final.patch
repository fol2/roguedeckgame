+      candidateCardInstanceIds: actor.plan?.candidateSequences.flatMap((sequence) => sequence.steps.map((step) => step.cardInstanceId)) ?? [],
+      sequenceCardInstanceIds: actor.plan?.sequence.steps.map((step) => step.cardInstanceId) ?? []
+    },
+    discardPile: actor.discardPile,
+    exhaustPile: actor.exhaustPile
+  }));
+
+  return {
+    ...state,
+    cardInstances: playerCards,
+    drawPile: playerActor?.drawPile ?? state.drawPile,
+    hand: playerActor?.hand ?? state.hand,
+    discardPile: playerActor?.discardPile ?? state.discardPile,
+    exhaustPile: playerActor?.exhaustPile ?? state.exhaustPile,
+    energy: playerActor?.resources.energy ?? state.energy,
+    maxEnergy: playerActor?.resources.maxEnergy ?? state.maxEnergy,
+    monsterIntents,
+    plannedMonsterAbilities: plannedAbilities,
+    monsterCardStates
+  };
+};
+
+export const clearActorPlans = (state: CombatState): CombatState => syncCombatProjections({
+  ...state,
+  cardActors: state.cardActors.map((actor) => ({ ...actor, planned: [], plan: undefined })),
+  teamPlans: []
+});
