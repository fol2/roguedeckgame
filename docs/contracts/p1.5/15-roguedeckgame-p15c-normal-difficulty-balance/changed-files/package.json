{
  "name": "roguedeckgame",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:cli": "vite build --config vite.cli.config.ts",
    "game:cli": "node scripts/run-cli-entry.mjs game-cli",
    "sim:smoke": "node scripts/run-cli-entry.mjs simulate-runs --mode smoke",
    "sim:fuzz": "node scripts/run-cli-entry.mjs simulate-runs --mode fuzz",
    "sim:analyze": "node scripts/run-cli-entry.mjs simulate-runs --mode fuzz --analyze",
    "sim:balance": "node scripts/run-cli-entry.mjs simulate-runs --mode fuzz --analyze --strict-health --strict-balance --runs 200 --max-steps 700 --seed balance-normal --invalid-action-rate 0",
    "sim:exhaustive-small": "node scripts/run-cli-entry.mjs simulate-runs --mode exhaustive-small",
    "sim:replay": "node scripts/run-cli-entry.mjs simulate-runs --mode replay",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "zip:review": "node scripts/create-review-zip.mjs",
    "smoke:localhost": "vitest run tests/game-core/localhost-smoke.test.js --reporter=verbose",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "typescript": "^5.9.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "phaser": "^4.1.0"
  }
}
