{
  "name": "roguedeckgame",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:cli": "vite build --config vite.cli.config.ts",
    "game:cli": "node scripts/run-cli-entry.mjs game-cli",
    "game:auto": "node scripts/run-cli-entry.mjs game-cli --seed cli-dev --auto",
    "game:auto:json": "node scripts/run-cli-entry.mjs game-cli --seed cli-dev --json --auto",
    "game:help": "node scripts/run-cli-entry.mjs game-cli --help",
    "game:version": "node scripts/run-cli-entry.mjs game-cli --version",
    "sim:smoke": "node scripts/run-cli-entry.mjs simulate-runs --mode smoke",
    "sim:fuzz": "node scripts/run-cli-entry.mjs simulate-runs --mode fuzz",
    "sim:analyze": "node scripts/run-cli-entry.mjs simulate-runs --mode fuzz --analyze",
    "sim:balance": "node scripts/run-cli-entry.mjs simulate-runs --mode fuzz --analyze --strict-health --strict-balance --seed balance-normal --invalid-action-rate 0",
    "sim:exhaustive-small": "node scripts/run-cli-entry.mjs simulate-runs --mode exhaustive-small",
    "sim:replay": "node scripts/run-cli-entry.mjs simulate-runs --mode replay",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "zip:review": "node scripts/create-review-zip.mjs",
    "smoke:localhost": "vitest run tests/game-core/localhost-smoke.test.js --reporter=verbose",
    "test": "vitest run --config vitest.config.ts --pool=threads --maxWorkers=4 --testTimeout=20000 --teardownTimeout=5000",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "test:core": "vitest run --config vitest.config.ts --pool=threads --maxWorkers=4 --testTimeout=20000 tests/game-core --reporter=dot",
    "test:phaser": "vitest run --config vitest.config.ts --pool=threads --maxWorkers=4 --testTimeout=20000 tests/game-phaser --reporter=dot",
    "test:cli": "vitest run --config vitest.config.ts --pool=threads --maxWorkers=2 --testTimeout=20000 tests/game-cli --reporter=dot",
    "test:scripts": "vitest run --config vitest.config.ts --pool=threads --maxWorkers=2 --testTimeout=20000 tests/scripts --reporter=dot"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "typescript": "^5.9.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "phaser": "^4.1.0"
  }
}
